# Base image
FROM python:3.9-slim

# Set working directory
WORKDIR /app

# Install dependencies
COPY requirements_ensemble.txt .
RUN pip install --no-cache-dir -r requirements_ensemble.txt

# Copy project files
COPY . .

# Environment variables
ENV PYTHONUNBUFFERED=1

# Command to run (can be overridden)
CMD ["python", "experiments/flexible_ensemble_pyramid.py"]

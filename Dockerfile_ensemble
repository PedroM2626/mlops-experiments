# Base image
FROM python:3.9-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    software-properties-common \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies
COPY requirements_ensemble.txt .
RUN pip install --no-cache-dir -r requirements_ensemble.txt

# Copy project files
COPY . .

# Environment variables
ENV PYTHONUNBUFFERED=1

# Expose Streamlit port
EXPOSE 8501

# Command to run (can be overridden)
# To run the core: python experiments/flexible_ensemble_pyramid.py
# To run the UI: streamlit run experiments/flexible_ensemble_pyramid_ui_enhanced.py
CMD ["streamlit", "run", "experiments/flexible_ensemble_pyramid_ui_enhanced.py", "--server.port=8501", "--server.address=0.0.0.0"]
